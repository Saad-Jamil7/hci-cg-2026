<button id="actionBtn" 
        style="padding: 10px 20px; margin: 10px 0; cursor: pointer; transition: all 0.1s ease;"
        onmouseover="if(!this.disabled) this.style.backgroundColor='#e0e0e0'"
        onmouseout="if(!this.disabled) this.style.backgroundColor=''">
  Process Data
</button>
<div id="status" style="margin-top: 10px;"></div>

<script>
  let count = 0;
  const btn = document.getElementById("actionBtn");
  const status = document.getElementById("status");
  
  function performAction() {
    if (btn.disabled) return;  // ✅ Prevents clicks after limit
    
    count++;
    btn.style.transform = "scale(0.95)";
    setTimeout(() => btn.style.transform = "", 100);
    
    if (count > 3) {
      btn.disabled = true;
      btn.style.opacity = "0.5";
      btn.style.cursor = "not-allowed";
      status.innerHTML = '<span style="color: red;">⚠️ Limit reached! Reload to try again.</span>';
    } else {
      status.innerHTML = `✅ Processed ${count} time${count > 1 ? 's' : ''}`;
    }
  }
  
  // Attach event listener properly
  btn.addEventListener("click", performAction);
</script>
